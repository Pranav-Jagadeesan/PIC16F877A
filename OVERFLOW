#include <xc.h>

#pragma config FOSC = HS
#pragma config WDTE = OFF
#pragma config PWRTE = OFF
#pragma config BOREN = OFF
#pragma config LVP = OFF
#pragma config CPD = OFF
#pragma config WRT = OFF
#pragma config CP = OFF

#define _XTAL_FREQ 2000000

unsigned char sw = 0;

void __interrupt() isr(void)
{
    if (TMR0IF)
    {
        TMR0IF = 0;

        if (sw == 0)
        {
            RB1 = 1;
            RB2 = 0; 
            RB3 = 0;
            RB4 = 0;
            RB5 = 0;
            RB6 = 1;
            sw= 1;
        }
        else if (sw== 1)
        {
            RB1 = 0; 
            RB2 = 1; 
            RB3 = 0;
            RB4 = 0; 
            RB5 = 1; 
            RB6 = 0;
            sw = 2;
        }
        else if (sw == 2)
        {
            RB1 = 0; 
            RB2 = 0; 
            RB3 = 1;
            RB4 = 1; 
            RB5 = 0; 
            RB6 = 0;
            sw = 0;
        }
    }
}

void main()
{
    TRISB1 = 0;
    TRISB2 = 0;
    TRISB3 = 0;
    TRISB4 = 0;
    TRISB5 = 0;
    TRISB6 = 0;

    RB1 = 0;
    RB2 = 0;
    RB3 = 0;
    RB4 = 0;
    RB5 = 0;
    RB6 = 0;

    OPTION_REGbits.T0CS = 0;
    OPTION_REGbits.PSA = 0;
    OPTION_REGbits.PS = 0b111;

    TMR0 = 0;
    TMR0IF = 0;
    TMR0IE = 1;
    GIE = 1;

    while(1)
    {
    }
}
